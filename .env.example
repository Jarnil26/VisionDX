# =============================================================
# .env.example — VisionDX Environment Variables
# =============================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to Git. It's in .gitignore.
# =============================================================

# ── Application ───────────────────────────────────────────────
APP_NAME=VisionDX
APP_ENV=development          # development | production
DEBUG=true                   # false in production
SECRET_KEY=CHANGE_ME_use_python_secrets_token_urlsafe_64

# ── Database ──────────────────────────────────────────────────
# Local SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./visiondx.db
DATABASE_URL_SYNC=sqlite:///./visiondx.db

# PostgreSQL (recommended for production on Render)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/visiondx
# DATABASE_URL_SYNC=postgresql://user:password@host:5432/visiondx

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=uploads           # /tmp/uploads on Render
MAX_UPLOAD_SIZE_MB=20

# ── ML Model ──────────────────────────────────────────────────
MODEL_PATH=visiondx/ml/models/disease_predictor.pkl

# ── OCR ───────────────────────────────────────────────────────
# Windows:  TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# Linux:    TESSERACT_CMD=/usr/bin/tesseract
# Render:   /usr/bin/tesseract  (auto-installed via apt)
TESSERACT_CMD=/usr/bin/tesseract

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Auth ──────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
